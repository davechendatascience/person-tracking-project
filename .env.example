# Copy to .env and adjust (optional). .env is gitignored.
#
# Managed network / custom CA bundle (if not using truststore alone):
# SSL_CERT_FILE=C:\path\to\ssl\cacert-combined.pem
# REQUESTS_CA_BUNDLE=C:\path\to\ssl\cacert-combined.pem
#
# Windows UTF-8 for Python (also set in scripts/Invoke-Boxmot.ps1):
# PYTHONUTF8=1
