# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.envs/

# uv (https://docs.astral.sh/uv/)
.uv/

# -----------------------------------------------------------------------------
# Secrets and local env (track .env.example as a template only)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# SSL / CA bundles (machine-specific; see scripts/Configure-PythonSSL.ps1)
# -----------------------------------------------------------------------------
ssl/cacert-combined.pem
ssl/*.pem
!ssl/.gitkeep

# -----------------------------------------------------------------------------
# Datasets, weights, archives (large / reproducible or downloaded)
# -----------------------------------------------------------------------------
# Root-level data dirs only (avoid ignoring a Python package named `data` elsewhere)
/data/
/datasets/
/raw/
/downloads/

# Caches created inside the repo (HF, pip, torch hubs, etc.)
**/.cache/

# Weight and export formats
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx
*.engine
*.plan
*.trt
*.mlmodel
*.tflite
*.h5
*.pb

# Archives (datasets, releases)
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z

# BoxMOT / TrackEval data trees populated after download
boxmot/engine/trackeval/data/

