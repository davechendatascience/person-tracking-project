<?xml version="1.0"?>
<!--
  Minimal nimble diff-drive follower mirroring the 2D sim's robot:
    body radius 0.25 m, max linear 1.5 m/s, max angular 1.5 rad/s.
  See ../../../follow_everything_nav2/sim/world.py for the sim params.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="follower">

  <xacro:property name="body_radius" value="0.25"/>
  <xacro:property name="body_height" value="0.15"/>
  <xacro:property name="body_mass"   value="6.0"/>
  <xacro:property name="wheel_radius" value="0.06"/>
  <xacro:property name="wheel_width"  value="0.04"/>
  <xacro:property name="wheel_mass"   value="0.5"/>
  <xacro:property name="wheel_sep"    value="0.40"/>
  <xacro:property name="caster_radius" value="0.03"/>

  <xacro:macro name="cyl_inertia" params="m r h">
    <inertia ixx="${m*(3*r*r + h*h)/12.0}" ixy="0" ixz="0"
             iyy="${m*(3*r*r + h*h)/12.0}" iyz="0"
             izz="${m*r*r/2.0}"/>
  </xacro:macro>

  <xacro:macro name="sph_inertia" params="m r">
    <inertia ixx="${2*m*r*r/5.0}" ixy="0" ixz="0"
             iyy="${2*m*r*r/5.0}" iyz="0"
             izz="${2*m*r*r/5.0}"/>
  </xacro:macro>

  <link name="base_footprint"/>

  <joint name="base_footprint_to_link" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry><cylinder radius="${body_radius}" length="${body_height}"/></geometry>
      <material name="green"><color rgba="0.1 0.7 0.2 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="${body_radius}" length="${body_height}"/></geometry>
    </collision>
    <inertial>
      <mass value="${body_mass}"/>
      <xacro:cyl_inertia m="${body_mass}" r="${body_radius}" h="${body_height}"/>
    </inertial>
  </link>

  <!-- forward arrow so heading is visible in Gazebo / RViz -->
  <link name="heading_marker">
    <visual>
      <origin xyz="0 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="0.02" length="${body_radius}"/></geometry>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
  </link>
  <joint name="base_to_heading" type="fixed">
    <parent link="base_link"/>
    <child link="heading_marker"/>
    <origin xyz="${body_radius/2} 0 ${body_height/2 + 0.01}" rpy="0 0 0"/>
  </joint>

  <xacro:macro name="wheel" params="prefix y_sign">
    <link name="${prefix}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="dark"><color rgba="0.1 0.1 0.1 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <inertial>
        <mass value="${wheel_mass}"/>
        <xacro:cyl_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
      </inertial>
    </link>
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel_link"/>
      <origin xyz="0 ${y_sign*wheel_sep/2} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit effort="20" velocity="${1.5/wheel_radius}"/>
      <dynamics damping="0.05" friction="0.05"/>
    </joint>
    <gazebo reference="${prefix}_wheel_link">
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>
      <kp>1e7</kp>
      <kd>1.0</kd>
    </gazebo>
  </xacro:macro>

  <xacro:wheel prefix="left"  y_sign=" 1"/>
  <xacro:wheel prefix="right" y_sign="-1"/>

  <!-- low-friction caster spheres front and back so the body stays balanced -->
  <xacro:macro name="caster" params="prefix x_sign">
    <link name="${prefix}_caster_link">
      <visual>
        <geometry><sphere radius="${caster_radius}"/></geometry>
        <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
      </visual>
      <collision>
        <geometry><sphere radius="${caster_radius}"/></geometry>
      </collision>
      <inertial>
        <mass value="0.05"/>
        <xacro:sph_inertia m="0.05" r="${caster_radius}"/>
      </inertial>
    </link>
    <joint name="${prefix}_caster_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${prefix}_caster_link"/>
      <origin xyz="${x_sign*(body_radius - caster_radius)} 0 ${-(wheel_radius - caster_radius)}" rpy="0 0 0"/>
    </joint>
    <gazebo reference="${prefix}_caster_link">
      <mu1>0.0</mu1>
      <mu2>0.0</mu2>
      <kp>1e6</kp>
      <kd>1.0</kd>
    </gazebo>
  </xacro:macro>

  <xacro:caster prefix="front" x_sign=" 1"/>
  <xacro:caster prefix="back"  x_sign="-1"/>

  <!-- Forward-facing RGB-D camera. 90° H-FOV matches the oracle's CAMERA_FOV_DEG
       so DAM4SAM detections are geometrically comparable to the oracle. The
       optical frame follows the REP-103 convention (camera_link → camera_optical
       with z-forward, x-right, y-down). -->
  <link name="camera_link">
    <visual>
      <geometry><box size="0.04 0.10 0.03"/></geometry>
      <material name="charcoal"><color rgba="0.15 0.15 0.15 1"/></material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>
  <joint name="base_to_camera" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="${body_radius - 0.02} 0 ${body_height/2 + 0.05}" rpy="0 0 0"/>
  </joint>
  <link name="camera_optical_frame"/>
  <joint name="camera_to_optical" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>
  <gazebo reference="camera_link">
    <sensor name="rgbd_camera" type="rgbd_camera">
      <topic>/follower/camera</topic>
      <update_rate>20</update_rate>
      <always_on>1</always_on>
      <visualize>false</visualize>
      <gz_frame_id>follower/camera_optical_frame</gz_frame_id>
      <camera>
        <horizontal_fov>1.5708</horizontal_fov>  <!-- 90° -->
        <image>
          <!-- 320x240 to keep RGB + depth payload under the bridge buffer
               threshold that triggered "sequence size exceeds remaining
               buffer" at 640x480. Bump back up once Phase 4b is stable. -->
          <width>320</width>
          <height>240</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
        <distortion>
          <k1>0</k1><k2>0</k2><k3>0</k3><p1>0</p1><p2>0</p2>
        </distortion>
      </camera>
    </sensor>
  </gazebo>

  <!-- 2D LiDAR mount: matches sim/sensors.py LidarSensor (360°, 72 rays, 8 m). -->
  <link name="lidar_link">
    <visual>
      <geometry><cylinder radius="0.04" length="0.04"/></geometry>
      <material name="orange"><color rgba="1.0 0.55 0.0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.04" length="0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <xacro:cyl_inertia m="0.05" r="0.04" h="0.04"/>
    </inertial>
  </link>
  <joint name="base_to_lidar" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 ${body_height/2 + 0.02}" rpy="0 0 0"/>
  </joint>
  <gazebo reference="lidar_link">
    <sensor name="lidar" type="gpu_lidar">
      <topic>/follower/scan</topic>
      <update_rate>20</update_rate>
      <always_on>1</always_on>
      <visualize>true</visualize>
      <gz_frame_id>follower/lidar_link</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>72</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159265</min_angle>
            <max_angle> 3.14159265</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.12</min>
          <max>8.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>
    </sensor>
  </gazebo>

  <!-- Ignition Fortress diff-drive system. Output is on Gazebo Transport topics
       /follower/cmd_vel and /follower/odom; ros_gz_bridge mirrors them onto
       ROS topics with the same names (see launch/empty_bringup.launch.py). -->
  <gazebo>
    <plugin filename="ignition-gazebo-diff-drive-system"
            name="ignition::gazebo::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>${wheel_sep}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <max_linear_acceleration>3.0</max_linear_acceleration>
      <max_linear_velocity>1.5</max_linear_velocity>
      <max_angular_velocity>1.5</max_angular_velocity>
      <topic>/follower/cmd_vel</topic>
      <odom_topic>/follower/odom</odom_topic>
      <tf_topic>/follower/tf</tf_topic>
      <frame_id>follower/odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <odom_publish_frequency>50</odom_publish_frequency>
    </plugin>
    <plugin filename="ignition-gazebo-joint-state-publisher-system"
            name="ignition::gazebo::systems::JointStatePublisher">
      <topic>/follower/joint_states</topic>
    </plugin>
    <!-- Ground-truth pose for the oracle camera bridge comes from the world's
         SceneBroadcaster (actor poses are not exposed by the per-model pose
         publisher, so we use SceneBroadcaster for both follower + actor). -->
  </gazebo>

</robot>
