<?xml version="1.0" ?>
<sdf version="1.9">
  <world name="empty">
    <plugin filename="ignition-gazebo-physics-system"
            name="ignition::gazebo::systems::Physics"/>
    <plugin filename="ignition-gazebo-user-commands-system"
            name="ignition::gazebo::systems::UserCommands"/>
    <plugin filename="ignition-gazebo-scene-broadcaster-system"
            name="ignition::gazebo::systems::SceneBroadcaster"/>
    <plugin filename="ignition-gazebo-sensors-system"
            name="ignition::gazebo::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <physics name="ode_200hz" type="ode">
      <max_step_size>0.005</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>200</real_time_update_rate>
    </physics>

    <scene>
      <ambient>0.6 0.6 0.6 1</ambient>
      <background>0.7 0.7 0.85 1</background>
      <shadows>false</shadows>
    </scene>

    <light type="directional" name="sun">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>1 1 1 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
          <!-- Explicit high friction. Without this, gz's default contact
               friction was leaving the wheels spinning in place. -->
          <surface>
            <friction>
              <ode>
                <mu>1.5</mu>
                <mu2>1.5</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ==============================================================
         FOLLOWER — native SDF (replaces the URDF that gz-sim's
         URDF→SDF converter was silently mangling). Diff-drive plugin,
         360° lidar, RGB-D camera, pose publisher, joint-state publisher
         all attached directly here.
         Pattern follows gz-sim Fortress's `vehicle_blue` reference robot:
         joint poses use `relative_to=chassis`, link poses use
         `relative_to=<joint>`, axis is expressed in __model__.
         ============================================================== -->
    <model name="follower">
      <pose>0 0 0 0 0 0</pose>
      <self_collide>false</self_collide>

      <link name="chassis">
        <!-- Chassis center at z=0.10. Body cylinder is 10 cm tall →
             extends from z=0.05 to z=0.15. That's 5 cm clearance above
             the ground plane so the body itself never touches ground;
             wheels (and only the wheels) provide traction.
             Wheels live at z=0.06 (their joints, below) so they stick
             out 4 cm beneath the body's bottom face. -->
        <pose>0 0 0.10 0 0 0</pose>
        <inertial>
          <!-- Solid cylinder, m=6 kg, r=0.20 m, h=0.10 m:
               ixx=iyy=m(3r²+h²)/12 ≈ 0.065 ; izz=mr²/2=0.12.
               (Earlier ixx,iyy=0.045 violated ixx+iyy ≥ izz, which gz
               rejects with "invalid inertia".) -->
          <mass>6.0</mass>
          <inertia>
            <ixx>0.065</ixx><iyy>0.065</iyy><izz>0.12</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <visual name="body_visual">
          <geometry>
            <cylinder><radius>0.20</radius><length>0.10</length></cylinder>
          </geometry>
          <material>
            <ambient>0.1 0.7 0.2 1</ambient>
            <diffuse>0.1 0.7 0.2 1</diffuse>
          </material>
        </visual>
        <collision name="body_collision">
          <geometry>
            <cylinder><radius>0.20</radius><length>0.10</length></cylinder>
          </geometry>
        </collision>

        <!-- Forward "heading" arrow on top so the orientation is obvious. -->
        <visual name="heading_arrow">
          <pose>0.10 0 0.06 0 1.5708 0</pose>
          <geometry><cylinder><radius>0.02</radius><length>0.20</length></cylinder></geometry>
          <material><diffuse>0 0 0 1</diffuse></material>
        </visual>

        <!-- Frictionless caster spheres at front and back. They sit
             *under* the body (chassis-relative z=-0.07 → world z=0.03),
             radius 3 cm, so their bottom touches ground. mu=0 makes
             them slide cleanly instead of dragging. -->
        <visual name="caster_front_visual">
          <pose>0.15 0 -0.07 0 0 0</pose>
          <geometry><sphere><radius>0.03</radius></sphere></geometry>
          <material><diffuse>0.5 0.5 0.5 1</diffuse></material>
        </visual>
        <collision name="caster_front_collision">
          <pose>0.15 0 -0.07 0 0 0</pose>
          <geometry><sphere><radius>0.03</radius></sphere></geometry>
          <surface><friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction></surface>
        </collision>
        <visual name="caster_back_visual">
          <pose>-0.15 0 -0.07 0 0 0</pose>
          <geometry><sphere><radius>0.03</radius></sphere></geometry>
          <material><diffuse>0.5 0.5 0.5 1</diffuse></material>
        </visual>
        <collision name="caster_back_collision">
          <pose>-0.15 0 -0.07 0 0 0</pose>
          <geometry><sphere><radius>0.03</radius></sphere></geometry>
          <surface><friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction></surface>
        </collision>

        <!-- 360° gpu_lidar mounted on top of chassis. -->
        <sensor name="lidar" type="gpu_lidar">
          <pose>0 0 0.085 0 0 0</pose>
          <topic>/follower/scan</topic>
          <update_rate>20</update_rate>
          <always_on>1</always_on>
          <visualize>true</visualize>
          <gz_frame_id>follower/lidar_link</gz_frame_id>
          <lidar>
            <scan>
              <horizontal>
                <samples>72</samples>
                <resolution>1</resolution>
                <min_angle>-3.14159265</min_angle>
                <max_angle> 3.14159265</max_angle>
              </horizontal>
              <vertical>
                <samples>1</samples>
                <resolution>1</resolution>
                <min_angle>0</min_angle>
                <max_angle>0</max_angle>
              </vertical>
            </scan>
            <range>
              <min>0.12</min>
              <max>8.0</max>
              <resolution>0.01</resolution>
            </range>
          </lidar>
        </sensor>

        <!-- Forward-facing RGB-D camera. -->
        <sensor name="rgbd_camera" type="rgbd_camera">
          <pose>0.23 0 0.05 0 0 0</pose>
          <topic>/follower/camera</topic>
          <update_rate>20</update_rate>
          <always_on>1</always_on>
          <visualize>false</visualize>
          <gz_frame_id>follower/camera_optical_frame</gz_frame_id>
          <camera>
            <horizontal_fov>1.5708</horizontal_fov>
            <image>
              <width>320</width>
              <height>240</height>
              <format>R8G8B8</format>
            </image>
            <clip><near>0.1</near><far>10.0</far></clip>
          </camera>
        </sensor>
      </link>

      <!-- Driven wheels. The joint pose carries the rotation that lays
           the cylinder on its side along Y; the link inherits it via
           relative_to. -->
      <joint name="left_wheel_joint" type="revolute">
        <pose relative_to="chassis">0 0.25 -0.04 -1.5708 0 0</pose>
        <parent>chassis</parent>
        <child>left_wheel</child>
        <axis>
          <xyz expressed_in="__model__">0 1 0</xyz>
          <limit>
            <lower>-1.79e308</lower>
            <upper> 1.79e308</upper>
          </limit>
          <dynamics><damping>0.05</damping><friction>0.05</friction></dynamics>
        </axis>
      </joint>
      <link name="left_wheel">
        <pose relative_to="left_wheel_joint">0 0 0 0 0 0</pose>
        <inertial>
          <mass>0.5</mass>
          <inertia>
            <ixx>0.0005</ixx><iyy>0.0005</iyy><izz>0.0009</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
          <material><diffuse>0.1 0.1 0.1 1</diffuse></material>
        </visual>
        <collision name="collision">
          <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
          <surface>
            <friction><ode><mu>1.5</mu><mu2>1.5</mu2></ode></friction>
          </surface>
        </collision>
      </link>

      <joint name="right_wheel_joint" type="revolute">
        <pose relative_to="chassis">0 -0.25 -0.04 -1.5708 0 0</pose>
        <parent>chassis</parent>
        <child>right_wheel</child>
        <axis>
          <xyz expressed_in="__model__">0 1 0</xyz>
          <limit>
            <lower>-1.79e308</lower>
            <upper> 1.79e308</upper>
          </limit>
          <dynamics><damping>0.05</damping><friction>0.05</friction></dynamics>
        </axis>
      </joint>
      <link name="right_wheel">
        <pose relative_to="right_wheel_joint">0 0 0 0 0 0</pose>
        <inertial>
          <mass>0.5</mass>
          <inertia>
            <ixx>0.0005</ixx><iyy>0.0005</iyy><izz>0.0009</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
          <material><diffuse>0.1 0.1 0.1 1</diffuse></material>
        </visual>
        <collision name="collision">
          <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
          <surface>
            <friction><ode><mu>1.5</mu><mu2>1.5</mu2></ode></friction>
          </surface>
        </collision>
      </link>

      <plugin filename="ignition-gazebo-diff-drive-system"
              name="ignition::gazebo::systems::DiffDrive">
        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>
        <wheel_separation>0.5</wheel_separation>
        <wheel_radius>0.06</wheel_radius>
        <max_wheel_torque>200</max_wheel_torque>
        <topic>/follower/cmd_vel</topic>
        <odom_topic>/follower/odom</odom_topic>
        <tf_topic>/follower/tf</tf_topic>
        <frame_id>follower/odom</frame_id>
        <child_frame_id>chassis</child_frame_id>
        <odom_publish_frequency>50</odom_publish_frequency>
      </plugin>
      <plugin filename="ignition-gazebo-joint-state-publisher-system"
              name="ignition::gazebo::systems::JointStatePublisher">
        <topic>/follower/joint_states</topic>
      </plugin>
      <plugin filename="ignition-gazebo-pose-publisher-system"
              name="ignition::gazebo::systems::PosePublisher">
        <publish_link_pose>false</publish_link_pose>
        <publish_visual_pose>false</publish_visual_pose>
        <publish_collision_pose>false</publish_collision_pose>
        <publish_sensor_pose>false</publish_sensor_pose>
        <publish_model_pose>true</publish_model_pose>
        <publish_nested_model_pose>false</publish_nested_model_pose>
        <use_pose_vector_msg>true</use_pose_vector_msg>
        <update_frequency>30</update_frequency>
      </plugin>
    </model>

    <!-- Walking-human leader. Skeletal mesh + walk animation from Fuel; first
         run requires internet so the model is fetched into ~/.ignition/fuel.
         Trajectory: a slow rectangular patrol around the origin at ~0.7 m/s
         (slower than the follower's 1.5 m/s max so the follower can catch up).
         The Mingfei actor's mesh origin sits roughly at body-center, so
         trajectory z must be ~0.4959 m for the feet to land on the ground.
         z=1.0 floats; z=0 sinks the body underground.
    -->
    <actor name="leader">
      <pose>3 0 0.4959 0 0 1.5708</pose>
      <skin>
        <filename>https://fuel.gazebosim.org/1.0/Mingfei/models/actor/tip/files/meshes/walk.dae</filename>
        <scale>1.0</scale>
      </skin>
      <animation name="walking">
        <filename>https://fuel.gazebosim.org/1.0/Mingfei/models/actor/tip/files/meshes/walk.dae</filename>
        <interpolate_x>true</interpolate_x>
      </animation>
      <script>
        <loop>true</loop>
        <delay_start>0.0</delay_start>
        <auto_start>true</auto_start>
        <trajectory id="0" type="walking">
          <waypoint><time> 0</time><pose> 3  0 0.4959 0 0  1.5708</pose></waypoint>
          <waypoint><time> 6</time><pose> 3  4 0.4959 0 0  1.5708</pose></waypoint>
          <waypoint><time> 8</time><pose> 3  4 0.4959 0 0  3.1416</pose></waypoint>
          <waypoint><time>17</time><pose>-3  4 0.4959 0 0  3.1416</pose></waypoint>
          <waypoint><time>19</time><pose>-3  4 0.4959 0 0 -1.5708</pose></waypoint>
          <waypoint><time>28</time><pose>-3 -2 0.4959 0 0 -1.5708</pose></waypoint>
          <waypoint><time>30</time><pose>-3 -2 0.4959 0 0  0     </pose></waypoint>
          <waypoint><time>39</time><pose> 3 -2 0.4959 0 0  0     </pose></waypoint>
          <waypoint><time>41</time><pose> 3 -2 0.4959 0 0  1.5708</pose></waypoint>
          <waypoint><time>44</time><pose> 3  0 0.4959 0 0  1.5708</pose></waypoint>
        </trajectory>
      </script>
      <!-- Note: gz-sim Fortress's SceneBroadcaster does NOT publish actor
           entity poses on any /world/<world>/*pose* topic, and the
           pose-publisher-system can't attach to <actor>. The oracle camera
           reconstructs the leader's pose by replaying the trajectory above
           from /clock — see sim/python/oracle_camera.py::LEADER_WAYPOINTS.
           If you change the trajectory, mirror the change there. -->
    </actor>
  </world>
</sdf>
