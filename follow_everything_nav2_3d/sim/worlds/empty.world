<?xml version="1.0" ?>
<sdf version="1.9">
  <world name="empty">
    <plugin filename="ignition-gazebo-physics-system"
            name="ignition::gazebo::systems::Physics"/>
    <plugin filename="ignition-gazebo-user-commands-system"
            name="ignition::gazebo::systems::UserCommands"/>
    <plugin filename="ignition-gazebo-scene-broadcaster-system"
            name="ignition::gazebo::systems::SceneBroadcaster"/>
    <plugin filename="ignition-gazebo-sensors-system"
            name="ignition::gazebo::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <physics name="ode_200hz" type="ode">
      <max_step_size>0.005</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>200</real_time_update_rate>
    </physics>

    <scene>
      <ambient>0.6 0.6 0.6 1</ambient>
      <background>0.7 0.7 0.85 1</background>
      <shadows>false</shadows>
    </scene>

    <light type="directional" name="sun">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>1 1 1 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
          <!-- Explicit high friction. Without this, gz's default contact
               friction was leaving the wheels spinning in place. -->
          <surface>
            <friction>
              <ode>
                <mu>1.5</mu>
                <mu2>1.5</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ==============================================================
         FOLLOWER — native SDF (replaces the URDF that gz-sim's
         URDF→SDF converter was silently mangling). Diff-drive plugin,
         360° lidar, RGB-D camera, pose publisher, joint-state publisher
         all attached directly here.
         Pattern follows gz-sim Fortress's `vehicle_blue` reference robot:
         joint poses use `relative_to=chassis`, link poses use
         `relative_to=<joint>`, axis is expressed in __model__.
         ============================================================== -->
    <model name="follower">
      <pose>0 0 0 0 0 0</pose>
      <self_collide>false</self_collide>

      <link name="chassis">
        <!-- Chassis center at z=0.10. Body cylinder is 10 cm tall →
             extends from z=0.05 to z=0.15. That's 5 cm clearance above
             the ground plane so the body itself never touches ground;
             wheels (and only the wheels) provide traction.
             Wheels live at z=0.06 (their joints, below) so they stick
             out 4 cm beneath the body's bottom face. -->
        <pose>0 0 0.10 0 0 0</pose>
        <inertial>
          <!-- Heavy ballast (25 kg) with the COM pinned at the BOTTOM of
               the chassis (link-relative z=-0.04 → world z=0.06, almost
               at the wheel contact line). Combined with the wide 0.5 m
               wheel track, this gives a tipping moment large enough
               that bumps just push the bot sideways instead of rocking
               it onto one wheel — even though the visual mast extends
               1.6 m up, no physical mass lives up there.

               For a uniform-density cylinder of m=25 kg, r=0.20 m,
               h=0.10 m: ixx=iyy=m(3r²+h²)/12 ≈ 0.27 ; izz=mr²/2=0.50.
               Triangle inequality (ixx+iyy ≥ izz) holds (0.54 ≥ 0.50). -->
          <pose>0 0 -0.04 0 0 0</pose>
          <mass>25.0</mass>
          <inertia>
            <ixx>0.27</ixx><iyy>0.27</iyy><izz>0.50</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <visual name="body_visual">
          <geometry>
            <cylinder><radius>0.20</radius><length>0.10</length></cylinder>
          </geometry>
          <material>
            <ambient>0.1 0.7 0.2 1</ambient>
            <diffuse>0.1 0.7 0.2 1</diffuse>
          </material>
        </visual>
        <collision name="body_collision">
          <geometry>
            <cylinder><radius>0.20</radius><length>0.10</length></cylinder>
          </geometry>
        </collision>

        <!-- Forward "heading" arrow on top so the orientation is obvious. -->
        <visual name="heading_arrow">
          <pose>0.10 0 0.06 0 1.5708 0</pose>
          <geometry><cylinder><radius>0.02</radius><length>0.20</length></cylinder></geometry>
          <material><diffuse>0 0 0 1</diffuse></material>
        </visual>

        <!-- Mast (visual only, no collision) carrying the RGBD camera at
             ~1.30 m world height — below the 1.5 m walls so the bot can't
             see over them. Mast is 1.20 m long, centered at chassis-frame
             z=0.60 so it spans z=0 → z=1.20 (just up to camera mount). -->
        <visual name="mast_visual">
          <pose>0 0 0.60 0 0 0</pose>
          <geometry><cylinder><radius>0.04</radius><length>1.20</length></cylinder></geometry>
          <material>
            <ambient>0.20 0.20 0.20 1</ambient>
            <diffuse>0.20 0.20 0.20 1</diffuse>
          </material>
        </visual>

        <!-- Frictionless caster spheres at front and back. They sit
             *under* the body (chassis-relative z=-0.07 → world z=0.03),
             radius 3 cm, so their bottom touches ground. mu=0 makes
             them slide cleanly instead of dragging. -->
        <visual name="caster_front_visual">
          <pose>0.15 0 -0.07 0 0 0</pose>
          <geometry><sphere><radius>0.03</radius></sphere></geometry>
          <material><diffuse>0.5 0.5 0.5 1</diffuse></material>
        </visual>
        <collision name="caster_front_collision">
          <pose>0.15 0 -0.07 0 0 0</pose>
          <geometry><sphere><radius>0.03</radius></sphere></geometry>
          <surface><friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction></surface>
        </collision>
        <visual name="caster_back_visual">
          <pose>-0.15 0 -0.07 0 0 0</pose>
          <geometry><sphere><radius>0.03</radius></sphere></geometry>
          <material><diffuse>0.5 0.5 0.5 1</diffuse></material>
        </visual>
        <collision name="caster_back_collision">
          <pose>-0.15 0 -0.07 0 0 0</pose>
          <geometry><sphere><radius>0.03</radius></sphere></geometry>
          <surface><friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction></surface>
        </collision>

        <!-- 360° gpu_lidar mounted on top of chassis. -->
        <sensor name="lidar" type="gpu_lidar">
          <pose>0 0 0.085 0 0 0</pose>
          <topic>/follower/scan</topic>
          <update_rate>20</update_rate>
          <always_on>1</always_on>
          <visualize>true</visualize>
          <gz_frame_id>follower/lidar_link</gz_frame_id>
          <lidar>
            <scan>
              <horizontal>
                <samples>72</samples>
                <resolution>1</resolution>
                <min_angle>-3.14159265</min_angle>
                <max_angle> 3.14159265</max_angle>
              </horizontal>
              <vertical>
                <samples>1</samples>
                <resolution>1</resolution>
                <min_angle>0</min_angle>
                <max_angle>0</max_angle>
              </vertical>
            </scan>
            <range>
              <min>0.12</min>
              <max>8.0</max>
              <resolution>0.01</resolution>
            </range>
          </lidar>
        </sensor>

        <!-- Forward-facing RGB-D camera, mounted on the mast at world
             z ≈ 1.30 m (chassis link is at world z=0.10, so chassis-frame
             z=1.20). Below the 1.5 m wall/obstacle height so the bot
             can't peek over them — earlier mounted at z=1.55 m, just
             above wall tops, which let SAM2 sometimes lock onto the
             leader through what should have been an opaque obstacle.
             Roughly chest-height of the 1.7 m leader. The edgetam_tracker
             CAM_OFFSET_X_BODY / CAM_OFFSET_Z_BODY constants must match. -->
        <sensor name="rgbd_camera" type="rgbd_camera">
          <pose>0.10 0 1.20 0 0 0</pose>
          <topic>/follower/camera</topic>
          <update_rate>20</update_rate>
          <always_on>1</always_on>
          <visualize>false</visualize>
          <gz_frame_id>follower/camera_optical_frame</gz_frame_id>
          <camera>
            <horizontal_fov>1.5708</horizontal_fov>
            <image>
              <width>320</width>
              <height>240</height>
              <format>R8G8B8</format>
            </image>
            <clip><near>0.1</near><far>10.0</far></clip>
          </camera>
        </sensor>
      </link>

      <!-- Driven wheels. The joint pose carries the rotation that lays
           the cylinder on its side along Y; the link inherits it via
           relative_to. -->
      <joint name="left_wheel_joint" type="revolute">
        <pose relative_to="chassis">0 0.25 -0.04 -1.5708 0 0</pose>
        <parent>chassis</parent>
        <child>left_wheel</child>
        <axis>
          <xyz expressed_in="__model__">0 1 0</xyz>
          <limit>
            <lower>-1.79e308</lower>
            <upper> 1.79e308</upper>
          </limit>
          <dynamics><damping>0.05</damping><friction>0.05</friction></dynamics>
        </axis>
      </joint>
      <link name="left_wheel">
        <pose relative_to="left_wheel_joint">0 0 0 0 0 0</pose>
        <inertial>
          <mass>0.5</mass>
          <inertia>
            <ixx>0.0005</ixx><iyy>0.0005</iyy><izz>0.0009</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
          <material><diffuse>0.1 0.1 0.1 1</diffuse></material>
        </visual>
        <collision name="collision">
          <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
          <surface>
            <friction><ode><mu>1.5</mu><mu2>1.5</mu2></ode></friction>
          </surface>
        </collision>
      </link>

      <joint name="right_wheel_joint" type="revolute">
        <pose relative_to="chassis">0 -0.25 -0.04 -1.5708 0 0</pose>
        <parent>chassis</parent>
        <child>right_wheel</child>
        <axis>
          <xyz expressed_in="__model__">0 1 0</xyz>
          <limit>
            <lower>-1.79e308</lower>
            <upper> 1.79e308</upper>
          </limit>
          <dynamics><damping>0.05</damping><friction>0.05</friction></dynamics>
        </axis>
      </joint>
      <link name="right_wheel">
        <pose relative_to="right_wheel_joint">0 0 0 0 0 0</pose>
        <inertial>
          <mass>0.5</mass>
          <inertia>
            <ixx>0.0005</ixx><iyy>0.0005</iyy><izz>0.0009</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
          <material><diffuse>0.1 0.1 0.1 1</diffuse></material>
        </visual>
        <collision name="collision">
          <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
          <surface>
            <friction><ode><mu>1.5</mu><mu2>1.5</mu2></ode></friction>
          </surface>
        </collision>
      </link>

      <!-- VelocityControl, NOT DiffDrive: cmd_vel is applied as a body-frame
           twist directly each step, kinematically. The 2D sim is fully
           kinematic and the BT's P-controllers were tuned against that —
           with DiffDrive's wheel torques + low joint damping the chassis
           carried angular momentum past the BT's w=0 command, overshooting
           target yaw and spinning past obstacles. VelocityControl makes the
           bot stop the instant the BT commands it to.
           Wheels are still in the URDF for the lidar mount + visual fidelity;
           they just don't drive. JointStatePublisher still publishes their
           (zero) state. /follower/odom comes from world_odom_publisher.py. -->
      <plugin filename="ignition-gazebo-velocity-control-system"
              name="ignition::gazebo::systems::VelocityControl">
        <topic>/follower/cmd_vel</topic>
      </plugin>
      <plugin filename="ignition-gazebo-joint-state-publisher-system"
              name="ignition::gazebo::systems::JointStatePublisher">
        <topic>/follower/joint_states</topic>
      </plugin>
      <plugin filename="ignition-gazebo-pose-publisher-system"
              name="ignition::gazebo::systems::PosePublisher">
        <publish_link_pose>false</publish_link_pose>
        <publish_visual_pose>false</publish_visual_pose>
        <publish_collision_pose>false</publish_collision_pose>
        <publish_sensor_pose>false</publish_sensor_pose>
        <publish_model_pose>true</publish_model_pose>
        <publish_nested_model_pose>false</publish_nested_model_pose>
        <use_pose_vector_msg>true</use_pose_vector_msg>
        <update_frequency>30</update_frequency>
      </plugin>
    </model>

    <!-- ==============================================================
         LEADER — humanoid-shaped <model> (replaces the previous <actor>).
         Why: Fortress's actor system doesn't publish entity poses to
         SceneBroadcaster, and gz interpolates the trajectory in a way
         we can't reproduce analytically (verified empirically). With a
         <model>, the pose-publisher-system gives us live ground truth
         on /model/leader/pose, and VelocityControl makes the model
         drivable via a Twist on /leader/cmd_vel.
         Visual: cylinder torso + sphere head + simple legs — distinct
         person silhouette so YOLO's "person" class still triggers.
         Trade-off vs the actor: no walking animation; the figure
         translates and rotates rigidly along the patrol path.
         ============================================================== -->
    <model name="leader">
      <!-- Leader spawns ~5 m in front of the camera. The follower's RGBD
           camera sits at body-frame x=0.23 (chassis 0 + sensor 0.23), so
           model x=5.5 puts the leader's body center 5.27 m from the camera.
           At 320×240 / 60° H-FOV (V-FOV ≈ 47°), a 1.7 m person fits fully
           only when distance > ~3.9 m; the extra 1 m of margin keeps the
           full body visible even when the bot is mid-rotation at frame 0. -->
      <pose>5.5 0 0 0 0 1.5708</pose>

      <link name="body">
        <inertial>
          <!-- Tall narrow person, mass 50 kg.
               Use rough principal moments; VelocityControl is kinematic
               (overrides physics integration) so exact values don't matter
               much, but they must be valid (triangle inequality). -->
          <mass>50.0</mass>
          <inertia>
            <ixx>10.0</ixx><iyy>10.0</iyy><izz>1.0</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>

        <!-- Body visual: Mingfei actor's static "stand" mesh from gz
             Fortress Fuel (https://fuel.gazebosim.org/1.0/Mingfei/models/actor).
             We use just the .dae mesh — NOT the <actor>+skin animation
             rig — so this stays a <model> that VelocityControl can
             drive. Trade-off: no walking-cycle animation; the figure
             translates and rotates rigidly. Gain: a real human-shape
             silhouette with texture, skin/clothing colour ratios, hair,
             arms — i.e. everything AOT/Cutie/EdgeTAM's appearance head
             was trained on YT-VOS / DAVIS to recognize as "person."
             The earlier cylinder+sphere primitives looked enough like
             cylindrical wall obstacles that AOT's memory attention
             couldn't reliably distinguish leader from environment.
             The mesh is pre-cached in the Dockerfile via
             `ign fuel download` so first launch works offline. -->
        <visual name="body_mesh">
          <!-- The Mingfei .dae's local origin is at the mesh's
               midpoint (~waist), not at the feet — same reason the
               actor's own model.sdf uses <pose>0 0 1.0 ...>.
               Raise the visual by 1.0 m so the feet land at the
               model frame's z=0 (ground). If the figure still hovers
               or sinks, nudge the z value here. -->
          <pose>0 0 1.0 0 0 0</pose>
          <geometry>
            <mesh>
              <uri>file:///root/.ignition/fuel/fuel.gazebosim.org/mingfei/models/actor/1/meshes/walk.dae</uri>
              <scale>1 1 1</scale>
            </mesh>
          </geometry>
        </visual>

        <!-- Single cylindrical collision approximating the whole body
             so the lidar / camera see a person-sized obstacle. -->
        <collision name="body_collision">
          <pose>0 0 0.85 0 0 0</pose>
          <geometry><cylinder><radius>0.20</radius><length>1.70</length></cylinder></geometry>
          <surface>
            <friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction>
          </surface>
        </collision>
      </link>

      <!-- VelocityControl applies a body-frame Twist (linear x = forward,
           angular z = yaw rate) to the model each step, kinematically.
           No wheels needed; the model just glides. The Python controller
           in sim/python/leader_controller.py drives this topic. -->
      <plugin filename="ignition-gazebo-velocity-control-system"
              name="ignition::gazebo::systems::VelocityControl">
        <topic>/leader/cmd_vel</topic>
      </plugin>

      <!-- Now SceneBroadcaster will publish this model's pose on
           /world/empty/dynamic_pose/info as it moves. -->
      <plugin filename="ignition-gazebo-pose-publisher-system"
              name="ignition::gazebo::systems::PosePublisher">
        <publish_link_pose>false</publish_link_pose>
        <publish_visual_pose>false</publish_visual_pose>
        <publish_collision_pose>false</publish_collision_pose>
        <publish_sensor_pose>false</publish_sensor_pose>
        <publish_model_pose>true</publish_model_pose>
        <publish_nested_model_pose>false</publish_nested_model_pose>
        <use_pose_vector_msg>true</use_pose_vector_msg>
        <update_frequency>30</update_frequency>
      </plugin>
    </model>
  </world>
</sdf>
